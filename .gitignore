# ── Virtual Environment ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pycache
PLAN.md

# ── Trained Model ──────────────────────────────────────────────────────────
